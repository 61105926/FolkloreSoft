# ════════════════════════════════════════════════════════════════════
#  Variables de entorno para Coolify
#  La base de datos MySQL corre DENTRO del mismo contenedor.
# ════════════════════════════════════════════════════════════════════

# Contraseña interna de la base de datos (puedes dejarla o cambiarla)
DB_PASSWORD=root
DB_ROOT_PASSWORD=root

# Conexión a MySQL (local: localhost / Docker: db)
DATABASE_URL=mysql://folklosoft:root@localhost:3306/folklosoft

# Secreto JWT — genera uno seguro con: openssl rand -base64 64
JWT_SECRET=nicolas90gabo

# Tiempo de expiración del token de acceso
JWT_ACCESS_EXPIRES_IN=15m

# URL pública del frontend (tu dominio en Coolify)
FRONTEND_URL=https://tudominio.com

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Auth
// ─────────────────────────────────────────

enum Rol {
  SUPERADMIN
  ADMIN
  VENDEDOR
  BODEGUERO
  CAJERO
}

model User {
  id               Int               @id @default(autoincrement())
  nombre           String            @default("Sin nombre")
  email            String            @unique
  password_hash    String
  rol              Rol               @default(VENDEDOR)
  activo           Boolean           @default(true)
  sucursalId       Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  refreshTokens    RefreshToken[]
  movimientosCaja  MovimientoCaja[]
  movimientosStock MovimientoStock[]
  sucursal         Sucursal?         @relation(fields: [sucursalId], references: [id], onDelete: SetNull)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(512)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// Sucursales
// ─────────────────────────────────────────

model Sucursal {
  id                   Int                   @id @default(autoincrement())
  nombre               String
  ciudad               String
  direccion            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  instanciasComponente InstanciaComponente[]
  eventos              EventoFolclorico[]
  usuarios             User[]
  movimientosCaja      MovimientoCaja[]
  contratos            ContratoAlquiler[]
}

// ─────────────────────────────────────────
// Catálogo (plantillas / diseños)
// ─────────────────────────────────────────

model Conjunto {
  id                  Int                  @id @default(autoincrement())
  codigo              String?              @unique
  nombre              String
  danza               String               // categoría (Tinku, Morenada, Caporales…)
  genero              String               @default("UNISEX")
  descripcion         String?              @db.Text
  imagen_url          String?
  precio_base         Decimal              @db.Decimal(10, 2) // precio alquiler/día
  precio_venta        Decimal?             @db.Decimal(10, 2)
  disponible_venta    Boolean              @default(true)
  disponible_alquiler Boolean              @default(true)
  activo              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  componentes         ConjuntoComponente[]
  variaciones         VariacionConjunto[]
  contratosPrendas    ContratoPrenda[]
}

model VariacionConjunto {
  id               Int               @id @default(autoincrement())
  codigo_variacion String            @unique
  nombre_variacion String
  talla            String?
  color            String?
  estilo           String?
  precio_venta     Decimal?          @db.Decimal(10, 2)
  precio_alquiler  Decimal?          @db.Decimal(10, 2)
  activa           Boolean           @default(true)
  conjuntoId       Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  conjunto         Conjunto          @relation(fields: [conjuntoId], references: [id], onDelete: Cascade)
  contratoPrendas  ContratoPrenda[]
  movimientosStock MovimientoStock[]
}

model Componente {
  id          Int                   @id @default(autoincrement())
  nombre      String
  tipo        String                // BLUSA | POLLERA | SOMBRERO | BOTAS | MASCARA | etc.
  descripcion String?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  conjuntos   ConjuntoComponente[]
  instancias  InstanciaComponente[]
}

// Receta: qué componentes necesita un conjunto y en qué cantidad
model ConjuntoComponente {
  id                Int        @id @default(autoincrement())
  conjuntoId        Int
  componenteId      Int
  cantidad          Int        @default(1)
  es_obligatorio    Boolean    @default(true)
  es_intercambiable Boolean    @default(false)
  orden_ensamblaje  Int        @default(0)
  conjunto          Conjunto   @relation(fields: [conjuntoId], references: [id], onDelete: Cascade)
  componente        Componente @relation(fields: [componenteId], references: [id], onDelete: Cascade)

  @@unique([conjuntoId, componenteId])
}

// ─────────────────────────────────────────
// Stock de conjuntos (por cantidad, sin instancias individuales)
// ─────────────────────────────────────────

enum TipoMovimientoStock {
  COMPRA  // Entrada de nuevos trajes al inventario
  BAJA    // Traje dañado, perdido o dado de baja
  AJUSTE  // Corrección manual del inventario
}

model MovimientoStock {
  id          Int                 @id @default(autoincrement())
  variacionId Int
  tipo        TipoMovimientoStock
  cantidad    Int                 // positivo = entrada, negativo = salida
  motivo      String?
  userId      Int?
  createdAt   DateTime            @default(now())
  variacion   VariacionConjunto   @relation(fields: [variacionId], references: [id], onDelete: Cascade)
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────
// Inventario físico de componentes sueltos
// ─────────────────────────────────────────

enum EstadoInstanciaComponente {
  DISPONIBLE_POOL
  ASIGNADO
  DANADO
  EN_TRANSFERENCIA
}

model InstanciaComponente {
  id           Int                       @id @default(autoincrement())
  serial       String                    @unique
  talla        String?
  componenteId Int
  sucursalId   Int
  estado       EstadoInstanciaComponente @default(DISPONIBLE_POOL)
  notas        String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  componente   Componente                @relation(fields: [componenteId], references: [id])
  sucursal     Sucursal                  @relation(fields: [sucursalId], references: [id])
}

// ─────────────────────────────────────────
// Eventos Folklóricos
// ─────────────────────────────────────────

enum TipoEvento {
  FESTIVAL
  CONCURSO
  DESFILE
  CEREMONIA
  OTRO
}

enum EstadoEvento {
  PLANIFICADO
  CONFIRMADO
  EN_CURSO
  FINALIZADO
  CANCELADO
}

model EventoFolclorico {
  id           Int               @id @default(autoincrement())
  nombre       String
  descripcion  String?           @db.Text
  tipo         TipoEvento        @default(FESTIVAL)
  estado       EstadoEvento      @default(PLANIFICADO)
  fecha_inicio DateTime
  fecha_fin    DateTime?
  lugar        String?
  sucursalId   Int?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  sucursal     Sucursal?         @relation(fields: [sucursalId], references: [id])
  contratos    ContratoAlquiler[]
}

// ─────────────────────────────────────────
// Clientes
// ─────────────────────────────────────────

model Cliente {
  id        Int                @id @default(autoincrement())
  nombre    String
  celular   String?
  ci        String?
  email     String?
  rol       String             @default("OTRO")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  contratos ContratoAlquiler[]
}

// ─────────────────────────────────────────
// Contratos de Alquiler
// ─────────────────────────────────────────

enum TipoContrato {
  DIRECTO
  RESERVA
}

enum EstadoContrato {
  RESERVADO
  CONFIRMADO
  ENTREGADO
  EN_USO
  DEVUELTO
  CERRADO
  CON_DEUDA
  CON_GARANTIA_RETENIDA
  CANCELADO
}

enum CiudadContrato {
  LA_PAZ
  EL_ALTO
  INTERIOR
}

enum TipoGarantia {
  EFECTIVO
  DOCUMENTO_CARNET
  CARTA_INSTITUCIONAL
  OTRO
}

enum FormaPago {
  EFECTIVO
  TRANSFERENCIA
  QR
  TARJETA
}

enum TipoParticipante {
  HOMBRE
  CHOLITA
  MACHA
  NINO
  OTRO
}

model ContratoAlquiler {
  id                    Int                    @id @default(autoincrement())
  codigo                String                 @unique
  tipo                  TipoContrato           @default(DIRECTO)
  estado                EstadoContrato         @default(RESERVADO)
  eventoId              Int?
  clienteId             Int
  nombre_evento_ext     String?
  institucion           String?
  ubicacion             String?
  ciudad                CiudadContrato         @default(LA_PAZ)
  fecha_contrato        DateTime               @default(now())
  fecha_entrega         DateTime
  fecha_devolucion      DateTime
  fecha_entrega_real    DateTime?
  fecha_devolucion_real DateTime?
  total                 Decimal                @default(0) @db.Decimal(10, 2)
  anticipo              Decimal                @default(0) @db.Decimal(10, 2)
  total_pagado          Decimal                @default(0) @db.Decimal(10, 2)
  forma_pago            FormaPago?
  observaciones         String?                @db.Text
  condiciones           String?                @db.Text
  sucursalId            Int?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  evento                EventoFolclorico?      @relation(fields: [eventoId], references: [id])
  cliente               Cliente                @relation(fields: [clienteId], references: [id])
  sucursal              Sucursal?              @relation(fields: [sucursalId], references: [id])
  prendas               ContratoPrenda[]
  garantias             ContratoGarantia[]
  participantes         ContratoParticipante[]
  historial             ContratoHistorial[]
  movimientosCaja       MovimientoCaja[]
}

model ContratoHistorial {
  id          Int              @id @default(autoincrement())
  contratoId  Int
  tipo        String
  descripcion String?          @db.Text
  createdAt   DateTime         @default(now())
  contrato    ContratoAlquiler @relation(fields: [contratoId], references: [id], onDelete: Cascade)
}

model ContratoPrenda {
  id                Int                    @id @default(autoincrement())
  contratoId        Int
  modelo            String
  conjuntoId        Int?
  variacionId       Int?
  cantidad_hombres  Int                    @default(0)
  cantidad_cholitas Int                    @default(0)
  cantidad_machas   Int                    @default(0)
  cantidad_ninos    Int                    @default(0)
  total             Int
  costo_unitario    Decimal                @db.Decimal(10, 2)
  subtotal          Decimal                @db.Decimal(10, 2)
  contrato          ContratoAlquiler       @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  conjunto          Conjunto?              @relation(fields: [conjuntoId], references: [id])
  variacion         VariacionConjunto?     @relation(fields: [variacionId], references: [id], onDelete: SetNull)
  participantes     ContratoParticipante[]
}

model ContratoGarantia {
  id               Int                   @id @default(autoincrement())
  contratoId       Int
  participanteId   Int?
  tipo             TipoGarantia
  descripcion      String?
  valor            Decimal?              @db.Decimal(10, 2)
  retenida         Boolean               @default(false)
  motivo_retencion String?
  createdAt        DateTime              @default(now())
  contrato         ContratoAlquiler      @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  participante     ContratoParticipante? @relation(fields: [participanteId], references: [id], onDelete: SetNull)
}

model ContratoParticipante {
  id               Int              @id @default(autoincrement())
  contratoId       Int
  prendaId         Int?
  nombre           String
  ci               String?
  celular          String?
  tipo             TipoParticipante @default(OTRO)
  notas            String?          @db.Text
  devuelto         Boolean          @default(false)
  fecha_devolucion DateTime?
  createdAt        DateTime         @default(now())
  contrato         ContratoAlquiler @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  prenda           ContratoPrenda?  @relation(fields: [prendaId], references: [id], onDelete: SetNull)
  garantias        ContratoGarantia[]
}

// ─────────────────────────────────────────
// Caja
// ─────────────────────────────────────────

enum TipoMovimiento {
  INGRESO
  EGRESO
}

enum ConceptoCaja {
  ANTICIPO_CONTRATO
  PAGO_SALDO_CONTRATO
  DEUDA_COBRADA
  GARANTIA_EFECTIVO
  DEVOLUCION_GARANTIA
  GASTO_OPERATIVO
  OTRO_INGRESO
  OTRO_EGRESO
}

model MovimientoCaja {
  id          Int               @id @default(autoincrement())
  tipo        TipoMovimiento
  concepto    ConceptoCaja
  monto       Decimal           @db.Decimal(10, 2)
  descripcion String?           @db.Text
  forma_pago  FormaPago         @default(EFECTIVO)
  referencia  String?
  contratoId  Int?
  userId      Int?
  sucursalId  Int?
  createdAt   DateTime          @default(now())
  contrato    ContratoAlquiler? @relation(fields: [contratoId], references: [id], onDelete: SetNull)
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  sucursal    Sucursal?         @relation(fields: [sucursalId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────
// Solicitudes web (catálogo público)
// ─────────────────────────────────────────

model SolicitudReservaWeb {
  id             Int       @id @default(autoincrement())
  nombre         String
  ci             String?
  celular        String
  evento         String?
  fecha_evento   DateTime?
  items          Json
  total_estimado Decimal   @db.Decimal(10, 2)
  anticipo_min   Decimal   @db.Decimal(10, 2)
  estado         String    @default("PENDIENTE") // PENDIENTE | CONTACTADO | CONVERTIDO | CANCELADO
  notas          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

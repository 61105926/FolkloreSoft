# ── Base de datos (servicio MySQL separado en Coolify) ───────────────────────
# Formato: mysql://usuario:password@host:3306/nombre_db
DATABASE_URL=mysql://folklosoft:password@db-host:3306/folklosoft

# ── JWT ──────────────────────────────────────────────────────────────────────
# Genera un secreto seguro con: openssl rand -base64 64
JWT_SECRET=cambia_esto_a_un_secreto_largo_y_seguro
JWT_ACCESS_EXPIRES_IN=15m

# ── URLs ─────────────────────────────────────────────────────────────────────
# URL pública del frontend (usada por el backend para CORS)
FRONTEND_URL=https://tudominio.com
